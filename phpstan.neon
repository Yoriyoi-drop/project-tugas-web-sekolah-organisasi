# phpstan.neon
includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    level: 5
    paths:
        - app/
        - database/factories/
        - database/seeders/
    excludePaths:
        - database/migrations/*
        - node_modules/*
        - storage/*
        - vendor/*
        - app/Http/Controllers/Auth/ResetPasswordController.php
    # Ignore errors for missing third-party classes/packages
    ignoreErrors:
        # Spatie packages (not installed in this project)
        - '#Class Spatie\\ResponseCache\\Middleware\\CacheResponse not found#'
        - '#Class Spatie\\ResponseCache\\Facades\\ResponseCache not found#'

        # Twilio package (optional dependency)
        - '#Class Twilio\\Rest\\Client not found#'

        # Intervention Image (optional dependency)
        - '#Call to static method make\(\) on an unknown class Intervention\\Image\\Facades\\Image#'

        # Laravel auth trait methods (PHPStan can't resolve trait methods)
        - '#Call to an undefined method .+::credentials\(\)#'
        - '#Call to an undefined method .+::redirectPath\(\)#'
        - '#Access to an undefined property .+::\$password#'

        # SecurityService static methods (dynamic class)
        - '#Call to an undefined static method App\\Services\\SecurityService::isStrongPassword\(\)#'

        # View string type issues (Laravel view names are dynamic strings)
        - '/Parameter #\d+ \$view of function view expects view-string/'

        # Repository interface methods (defined in concrete implementations)
        - '#Call to an undefined method App\\Repositories\\Contracts\\StudentRepositoryInterface::#'

        # Relation existence errors (Larastan can't resolve all dynamic relations)
        - '#Relation .* is not found in App\\Models#'

        # Nullsafe on non-nullable types (already guaranteed by casts/relations)
        - '#Using nullsafe (method call|property access) on non-nullable type#'

        # Mixin tag with missing class
        - '#PHPDoc tag @mixin contains unknown class#'

        # Instanceof always false (Carbon cast issues)
        - '#Instanceof between .+ and Carbon\\Carbon will always evaluate to false#'

        # Cannot call method on string (datetime cast attributes)
        - '#Cannot call method (diffInMinutes|isFuture)\(\) on string#'

        # Left/Right side of && is always true
        - '#(Left|Right) side of && is always (true|false)#'

        # If condition is always true
        - '#If condition is always true#'

        # Unreachable statement
        - '#Unreachable statement#'

        # BooleanAnd always false
        - '#Result of && is always (true|false)#'

        # View-string issues in Mailable classes
        - '/Parameter #\d+ \$view of method Illuminate\\\\Mail\\\\Mailable::view\(\) expects view-string/'

        # Deprecated implicitly nullable parameters
        - '#Deprecated in PHP 8\.4: Parameter .+ is implicitly nullable#'

        # Mailable view string (valid view names but PHPStan can't verify them)
        - '/Parameter #\d+ \$view of method Illuminate\\Mail\\Mailable::view\(\) expects view-string, string given/'

        # Collection map unresolvable type (PHPStan limitation with closures)
        - '/Parameter #\d+ \$callback of method Illuminate\\Database\\Eloquent\\Collection.*::map\(\) contains unresolvable type/'

        # Unknown trait (Laravel built-in trait that PHPStan can't resolve)
        - '/uses unknown trait Illuminate\\Foundation\\Auth\\ResetsPasswords/'

        # Trait method not found (PHPStan can't resolve trait methods)
        - '/Call to an undefined method .+::(credentials|redirectPath|rules|validationErrorMessages|broker|resetPassword|sendResetResponse)\(\)/'

        # Unmatched ignore patterns (don't report if patterns don't match)
    reportUnmatchedIgnoredErrors: false